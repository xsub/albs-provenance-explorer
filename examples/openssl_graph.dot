  "sbom:openssl:cyclonedx" [label="sbom\\nCycloneDX SBOM for openssl", fillcolor="#F1F8E9"];
  "external:zlib" [label="external_package\\nzlib runtime dependency", fillcolor="#FFFFFF"];
